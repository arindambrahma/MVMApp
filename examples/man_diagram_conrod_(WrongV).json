      "functionCode": "def rankine(Fp, sig_y_mat, FOS, K_rankine, lc, A_coeff, Ixx_coeff, HR, BR, N_rpm, overspeed, ls, rho):\n      fe = sig_y_mat / FOS\n      C_rankine = K_rankine * (lc**2) * (A_coeff / Ixx_coeff)\n\n      p = [A_coeff * fe, 0.0, -Fp, 0.0, -Fp * C_rankine]\n      roots_all = np.roots(p)\n\n      real_pos = [float(r.real) for r in roots_all if abs(float(r.imag)) < 1e-9 and float(r.real) > 0.0]\n      if not real_pos:\n          raise ValueError(\"No positive real thickness root found\")\n\n      t_req = min(real_pos)\n\n      H_req = t_req * HR\n      B_req = t_req * BR\n      h_req = H_req - (2.0 * t_req)\n      b_req = (B_req - t_req) / 2.0\n      A_req = A_coeff * (t_req**2)\n\n      n = (N_rpm * (1.0 + overspeed)) / 60.0\n      r = ls / 2.0\n      W = rho * 9.81\n      C = H_req / 2.0\n\n      return {\n          \"t_req\": t_req,\n          \"H_req\": H_req,\n          \"B_req\": B_req,\n          \"h_req\": h_req,\n          \"b_req\": b_req,\n          \"A_req\": A_req,\n          \"n\": n,\n          \"r\": r,\n          \"W\": W,\n          \"C\": C,\n          \"C_rankine\": C_rankine,\n      }",
      "decidedValue": "",
      "probeEdgeId": null,
      "probeEdgeT": 0.5,
      "clusterId": null,
      "isOfInterest": false,
      "stepNumber": 2,
      "autoLabel": "CF2",
