      "equation": "",
      "functionCode": "def perfpar_conrod(rho, lc, A_coeff, t_req, len, db_req, lb_req, Bolt_req, Nb, ds_req, ls_req, tcap_req):\n      A_req = A_coeff * (t_req**2)\n\n      V_rod = lc * A_req\n      M_rod = V_rod * rho / 1000000000\n\n      V_be = (len * (2 * db_req) * lb_req) - (np.pi * (db_req**2) * lb_req / 4)\n      M_be = V_be * rho / 1000000000\n\n      V_se = np.pi * (ds_req**2) * ls_req / 4\n      M_se = V_se * rho / 1000000000\n\n      V_bolt = 1.5 * np.pi * (Bolt_req**2) * lb_req * Nb / 4\n      M_bolt = V_bolt * rho / 1000000000\n\n      V_cap = len * tcap_req\n      M_cap = V_cap * rho / 1000000000\n\n      M_total = M_rod + M_be + M_se + M_cap + M_bolt\n      V_total = V_rod + V_be + V_se + V_cap + V_bolt\n\n      return {\n          \"V_rod\": V_rod,\n          \"M_rod\": M_rod,\n          \"V_be\": V_be,\n          \"M_be\": M_be,\n          \"V_se\": V_se,\n          \"M_se\": M_se,\n          \"V_bolt\": V_bolt,\n          \"M_bolt\": M_bolt,\n          \"V_cap\": V_cap,\n          \"M_cap\": M_cap,\n          \"V_total\": V_total,\n          \"M_total\": M_total,\n      }",
      "rootSelectionPolicy": "min",
      "decidedValue": "",
      "probeEdgeId": null,
      "probeEdgeT": 0.5,
