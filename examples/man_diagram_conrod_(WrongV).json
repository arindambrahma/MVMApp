      "functionCode": "def bolt_req(r, Wr, n, lc, Csteel, Nb, sig_bolt_allow):\n      Fi = 4.03e-3 * r * (n**2) * Wr * (1 + (r / lc))\n      Fin = Fi / 2\n      Ab_req = (Fin / Csteel) ** (1 / 1.418)\n      Boltd_req = (4 * Ab_req / np.pi) ** 0.5\n      return {\n          \"Ab_req\": Ab_req,\n          \"Fi\": Fi,\n          \"Boltd_req\": Boltd_req,\n      }",
